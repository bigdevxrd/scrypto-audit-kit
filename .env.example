# scrypto-audit-kit — Environment Variables
#
# Copy this to .env (gitignored) and fill in your API key.
#
# Required (default model is Claude Sonnet 4.6):
ANTHROPIC_API_KEY=sk-ant-...   # Claude API key (required for aider)
#
# Optional:
# DEEPSEEK_API_KEY=sk-...       # only needed for `--model deepseek` or `--model both`
# AIDER_ENV_FILE=/path/to/.env  # Alternative env file path
